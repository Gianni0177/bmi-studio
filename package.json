{
  "name": "bmi-studio",
  "version": "1.0.0",
  "description": "BMI Studio - Calcolatore BMI web e desktop",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build-web": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron-dev": "concurrently -k \"npm:dev\" \"npm:electron:wait\"",
    "electron:wait": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build-win": "npm run build-web && electron-builder --win nsis",
    "test": "echo \"Nessun test configurato\""
  },
  "keywords": [
    "bmi",
    "electron",
    "vite",
    "salute"
  ],
  "author": "",
  "license": "ISC",
  "build": {
    "appId": "com.bmistudio.app",
    "productName": "BMI Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "vite": "^5.4.19",
    "wait-on": "^7.2.0"
  }
}
